# k-ID CDK Explorer Environment Configuration

# Age Verification API Configuration
K_ID_API_KEY=your_actual_api_key_here
K_ID_API_URL=https://game-api.test.k-id.com

# Optional: Override default port (defaults to 3100)
PORT=3100

# Optional: Override local URL
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Language setting, `en` for English (default), `ja` for Japanese, `ko` for Korean, `zh` for Chinese
NEXT_PUBLIC_LOCALE=en

# Webhook Signature Validation (optional)
# If provided, webhook requests will be validated using HMAC-SHA256 signature verification
# Get your webhook secret from the k-ID Compliance Studio product settings
WEBHOOK_SECRET=your_webhook_secret_here
